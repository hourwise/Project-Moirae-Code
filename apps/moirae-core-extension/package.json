{
  "name": "@moirae/core-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Moirae Code VS Code extension — chat, approvals, memory explorer, audit timeline, runtime health",
  "license": "MIT",
  "main": "./dist/extension.js",
  "engines": { "vscode": "^1.95.0" },
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moirae",
          "title": "Moirae Code",
          "icon": "media/moirae-icon.svg"
        }
      ]
    },
    "views": {
      "moirae": [
        { "id": "moirae.thread", "name": "Thread" },
        { "id": "moirae.memory", "name": "Memory" },
        { "id": "moirae.authority", "name": "Authority" },
        { "id": "moirae.runtime", "name": "Runtime" }
      ]
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@moirae/runtime-contracts": "*",
    "@moirae/local-ipc": "*",
    "@moirae/provider-sdk": "*",
    "@moirae/tool-sdk": "*",
    "@moirae/policy-profiles": "*",
    "@moirae/ui-components": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0"
  }
}
